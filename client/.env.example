# ═══════════════════════════════════════════════════════════
#  UniBuddy Client — Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════

# URL of your backend server (no trailing slash)
# Dev:  http://localhost:3000
# Prod: https://your-render-service.onrender.com
VITE_APP_WEBSOCKET_URL=http://localhost:3000

# Set to "production" to enable production-only UI (email required, etc.)
VITE_APP_ENV=development

# Your VAPID public key (same as VAPID_PUBLIC_KEY in server .env)
# Needed for the Notify Me Web Push feature
VITE_VAPID_PUBLIC_KEY=
