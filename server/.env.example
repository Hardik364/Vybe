# ═══════════════════════════════════════════════════════════
#  UniBuddy Server — Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=development

# ── Frontend URL (used for CORS) ─────────────────────────────
# In dev: http://localhost:5173
# In prod: your Vercel URL, e.g. https://unibuddy.vercel.app
PUBLIC_WEBSOCKET_URL=http://localhost:5173

# ── Redis ────────────────────────────────────────────────────
# Local dev: defaults below work out of the box
# Production (Upstash): get values from console.upstash.com
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=
REDIS_TLS=false           # set to "true" for Upstash

# ── JWT Auth ─────────────────────────────────────────────────
# Any long random string — keep secret in production!
JWT_SECRET=change_me_to_a_long_random_string_in_production

# ── Email (OTP verification) ─────────────────────────────────
# Use a Gmail account + App Password (NOT your real password)
# Setup: myaccount.google.com → Security → 2-Step → App Passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── TURN Server (WebRTC relay for strict NAT) ────────────────
# Option A — Metered.ca (recommended, 50 GB/month free)
#   Sign up at: https://dashboard.metered.ca
METERED_API_KEY=
METERED_APP_NAME=

# Option B — Self-hosted Coturn
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# Option C — leave all above empty → uses open-relay (dev only)

# ── Razorpay Payments ─────────────────────────────────────────
# Test keys from: https://dashboard.razorpay.com/app/keys
# Test keys start with rzp_test_ — no real charges
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
WEBHOOK_SECRET=change_this_webhook_secret

# ── Web Push (Notify Me feature) ────────────────────────────
# Generate once with: node -e "import('web-push').then(({default:wp})=>console.log(JSON.stringify(wp.generateVAPIDKeys())))"
# NEVER regenerate after deployment — invalidates all user subscriptions
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@gmail.com

# ── Google Sign-In ───────────────────────────────────────────
# Same Client ID as on the frontend — used to verify the id_token server-side
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=

# ── Admin Dashboard ──────────────────────────────────────────
ADMIN_KEY=change_this_admin_key
STATS_KEY=change_this_stats_key
